# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Upstash Redis Configuration
# Get these from your Upstash Redis database: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Twilio <-> OpenAI Realtime bridge (custom Node Web‑Socket server only).
# TWILIO_BRIDGE_MANUAL_TURN_SILENCE_MS = fixed capture window (ms) after first speech-latched post-assistant inbound frame (legacy name).
# TWILIO_BRIDGE_MANUAL_FALLBACK_MIN_CHUNKS = min caller chunks before commit (0 disables chunk gate).
# TWILIO_BRIDGE_MANUAL_COMMIT_MIN_AUDIO_MS = min estimated caller audio (ms) before commit (0 disables).
# TWILIO_BRIDGE_MS_PER_INBOUND_CHUNK = ms added per append for estimate (default 20).
# TWILIO_BRIDGE_MAX_MS_SINCE_APPEND = freshness for commit (0 disables check; default 2000).
# TWILIO_BRIDGE_POST_ASSISTANT_IGNORE_MS = drop inbound toward OpenAI after response.done (echo tail); 0 disables (default 750).
# TWILIO_BRIDGE_WINDOW_ARM_MIN_MS / TWILIO_BRIDGE_WINDOW_ARM_MIN_CHUNKS = require this much allowed caller audio before arming fixed window (0 disables).
# TWILIO_BRIDGE_SPEECH_MEAN_ABS_THRESHOLD = mean |linear sample| per μ-law frame to count as high energy; 0 disables gate (not recommended; default 380).
# TWILIO_BRIDGE_SPEECH_MIN_HIGH_MS = consecutive high-energy frames must cover this many ms before speech is latched; 0 uses one chunk length (default 100).
# TWILIO_BRIDGE_CONFIRMATION_WAIT_MS = silence before issue-confirm reprompt / second wait (default 5500); 0 disables reprompt timers.
# Suggested first run: 1500 / 10 / 150, post-tail 750, arm 80ms / 4 chunks, speech 380 / 100ms
# TWILIO_BRIDGE_MANUAL_TURN_SILENCE_MS=1500
# TWILIO_BRIDGE_MANUAL_FALLBACK_MIN_CHUNKS=10
# TWILIO_BRIDGE_MANUAL_COMMIT_MIN_AUDIO_MS=150
# TWILIO_BRIDGE_POST_ASSISTANT_IGNORE_MS=750
# TWILIO_BRIDGE_WINDOW_ARM_MIN_MS=80
# TWILIO_BRIDGE_WINDOW_ARM_MIN_CHUNKS=4
# TWILIO_BRIDGE_SPEECH_MEAN_ABS_THRESHOLD=380
# TWILIO_BRIDGE_SPEECH_MIN_HIGH_MS=100

# OpenAI Realtime voice (Twilio inbound + /api/bot/voice/realtime-session).
# VOICE_REPEAT_BACK_ONLY = true|1|yes enables diagnostic repeat-back-only mode (no intake / issue gate). Not for production.
# VOICE_MODE_KITCHEN_SINK_LEAK_ONLY = true|1|yes | false|0|no — deterministic kitchen-sink-leak-only FSM (default ON in code when unset). Repeat-back wins if both are set. Disables legacy plumbing / single-lane tool path on the media WebSocket.
# VOICE_SINGLE_LANE_KITCHEN_SINK_ONLY = legacy tool-based single lane (only if kitchen-sink-only mode is off).
# For live calls, set this in .env.local (see server.ts: dotenv loads .env then .env.local with override). Logs: activeVoiceMode repeat_back_only | kitchen_sink_leak_only | single_lane_kitchen_sink | full_plumbing.
# TWILIO_ACCOUNT_SID = required for ending calls after unsupported single-lane refusal (with TWILIO_AUTH_TOKEN).
# OPENAI_REALTIME_SESSIONS_URL = optional POST URL for session creation (default https://api.openai.com/v1/realtime/sessions). Set to confirm proxy vs direct OpenAI in logs.
# Audit Version (optional, for tracking)
AUDIT_VERSION=1.0.0

# Database URL (legacy - will be removed after migration to Supabase)
# DATABASE_URL=your_postgresql_connection_string
